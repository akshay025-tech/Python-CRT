a=input("Enter your password: ")
up=0
lw=0
dg=0
sp=0
if len(a)>7:
    for i in a:
        if i.isupper():
            up=up+1
        elif i.islower():
            lw=lw+1
        elif i.isdigit():
            dg=dg+1
        else:
            sp=sp+1
else:
    print("Weak")
if up>0 and lw>0 and dg>0 and sp>0:
    print("Strong")
else:
    print("Weak due to less char")
        
